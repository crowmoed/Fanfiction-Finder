{
  "mcpServers": {
    "context7": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@upstash/context7-mcp"]
    },
    "repomix": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "repomix", "--mcp"]
    },
    "serena": {
      "command": "C:\\Users\\notcr\\AppData\\Local\\Programs\\Python\\Python312\\Scripts\\uvx.exe",
      "args": ["--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--context", "ide-assistant", "--project", "D:\\Fanfiction-Finder"]
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "deepwiki": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-remote", "https://mcp.deepwiki.com/mcp"]
    },
    "mermaid": {
      "command": "cmd",
      "args": ["/c", "npx", "-y", "mcp-mermaid"]
    }
  }
